{
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "allowJs": true,
        "checkJs": true, // JSファイルのチェックを有効化
        "noImplicitAny": false, // 型が不明な場合にanyを許容する
        "noUnusedLocals": false // 未使用変数の警告を消す
    },
    "exclude": [
        "petitnote/app/neo/*",
        "petitnote/app/chickenpaint/*",
        "petitnote/app/klecks/*",
        "petitnote/app/axnos/*",
        ".git"
    ]
}
